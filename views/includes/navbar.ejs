<style>
  .navbar-custom {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 0.8rem 1rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }
  
  .navbar-custom .navbar-brand {
    color: white !important;
    font-weight: 700;
    font-size: 1.5rem;
  }
  
  .navbar-custom .nav-link {
    color: rgba(255,255,255,0.9) !important;
    font-weight: 500;
    margin: 0 0.5rem;
    transition: all 0.3s;
    border-radius: 20px;
    padding: 0.5rem 1rem !important;
  }
  
  .navbar-custom .nav-link:hover {
    color: white !important;
    background: rgba(255,255,255,0.2);
    transform: translateY(-2px);
  }
  
  .navbar-custom .btn-add {
    background: #fe424d;
    color: white !important;
    border-radius: 25px;
    padding: 0.5rem 1.5rem !important;
    font-weight: 600;
  }
  
  .navbar-custom .btn-add:hover {
    background: #ff6b6b;
    transform: scale(1.05);
  }
  
  .search-nav {
    background: rgba(255,255,255,0.2);
    border: none;
    border-radius: 25px;
    color: white;
    padding: 0.5rem 1rem;
  }
  
  .search-nav::placeholder {
    color: rgba(255,255,255,0.7);
  }
  
  .search-btn-nav {
    background: white;
    color: #667eea;
    border: none;
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    font-weight: 600;
  }
</style>

<nav class="navbar navbar-expand-md navbar-custom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-house-chimney"></i> RentYourHouse
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarNav">
      <div class="navbar-nav mx-auto">
        <form class="d-flex" role="search">
          <input class="form-control me-2 search-nav" type="search" placeholder="Search destinations..." />
          <button class="btn search-btn-nav" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
          </button>
        </form>
      </div>
      
      <div class="navbar-nav">
        <a class="nav-link btn-add" href="/listings/new">
          <i class="fa-solid fa-plus"></i> Add your home
        </a>
        
        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>Sign up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>
        
        <% if(currUser) { %>
          <a class="nav-link" href="/bookings/my-bookings">
            <i class="fa-solid fa-calendar-check"></i> My Bookings
          </a>
          <a class="nav-link" href="/bookings/host-bookings">
            <i class="fa-solid fa-list-check"></i> Host Bookings
          </a>
          <a class="nav-link" href="/logout"><b>Log out</b></a>
        <% } %>
      </div>
    </div>
  </div>
</nav>