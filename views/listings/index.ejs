<% layout("/layouts/boilerplate") -%>
<%= success %>

<style>
  #filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .filters{
    text-align: center;
    margin-top: 2rem;
    margin-right: 2rem;
    opacity: 0.7;
    text-decoration: none;
    color: inherit;
  }
  .filters:hover {
    opacity: 1;
    cursor: pointer;
  }
  .filters p {
    font-size: 0.8rem;
    margin-bottom: 0;
  }

  .filters.active {
    opacity: 1;
    font-weight: 700;
    border-bottom: 2px solid black;
    padding-bottom: 4px;
  }

  .tax-info {
    display: none;
  }
  .tax-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 2rem;
    display: flex;
    align-items: center;
  }
</style>

<div id="filters">
  <a class="filters <%= (selectedCat === 'trending' || !selectedCat) ? 'active' : '' %>" href="/listings?cat=trending">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </a>

  <a class="filters <%= selectedCat === 'rooms' ? 'active' : '' %>" href="/listings?cat=rooms">
    <i class="fa-solid fa-bed"></i>
    <p>Room</p>
  </a>

  <a class="filters <%= selectedCat === 'iconic' ? 'active' : '' %>" href="/listings?cat=iconic">
    <i class="fa-solid fa-mountain-city"></i>
    <p>Iconic cities</p>
  </a>

  <a class="filters <%= selectedCat === 'mountains' ? 'active' : '' %>" href="/listings?cat=mountains">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </a>

  <a class="filters <%= selectedCat === 'castles' ? 'active' : '' %>" href="/listings?cat=castles">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>Castles</p>
  </a>

  <a class="filters <%= selectedCat === 'amazing_pools' ? 'active' : '' %>" href="/listings?cat=amazing_pools">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Amazing pools</p>
  </a>

  <a class="filters <%= selectedCat === 'camping' ? 'active' : '' %>" href="/listings?cat=camping">
    <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
  </a>

  <a class="filters <%= selectedCat === 'farms' ? 'active' : '' %>" href="/listings?cat=farms">
    <i class="fa-solid fa-tractor"></i>
    <p>Farms</p>
  </a>

  <a class="filters <%= selectedCat === 'arctic' ? 'active' : '' %>" href="/listings?cat=arctic">
    <i class="fa-solid fa-snowman"></i>
    <p>Arctic</p>
  </a>

  <a class="filters <%= selectedCat === 'domes' ? 'active' : '' %>" href="/listings?cat=domes">
    <i class="fa-solid fa-igloo"></i>
    <p>Domes</p>
  </a>

  <a class="filters <%= selectedCat === 'boats' ? 'active' : '' %>" href="/listings?cat=boats">
    <i class="fa-solid fa-sailboat"></i>
    <p>Boats</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display Total after taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for(let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">
        <img src="<%= listing.image.url%>" class="card-img-top" alt="listing image" style="height: 20rem">
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <%= listing.title %> <br>
            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            <i class="tax-info">&nbsp;&nbsp;:+18% GST</i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.querySelectorAll(".tax-info");
    for (let info of taxInfo) {
      info.style.display = taxSwitch.checked ? "inline" : "none";
    }
  });
</script>
